# ─── Database ───────────────────────────────────────────────────────────────
# Neon Postgres connection string
DATABASE_URL=postgresql://user:password@host/dbname

# Optional: a separate read-only URL for analytics/long-running queries.
# DATABASE_URL_READONLY=

# ─── Admin gate ─────────────────────────────────────────────────────────────
# Used to protect /admin and as the HMAC secret for the admin session cookie.
SCOREKEEPER_PIN=

# ─── Auth.js (player accounts) ──────────────────────────────────────────────
# Generate with `openssl rand -base64 32`. Required.
AUTH_SECRET=
# Required when running on Vercel preview/prod.
AUTH_TRUST_HOST=true

# ─── Resend (magic-link auth + transactional email) ─────────────────────────
# https://resend.com — verify a domain (e.g. bash.fan) before sending.
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM="BASH <noreply@bash.fan>"
# Used by registration confirmation email; can be the same key as AUTH_RESEND_KEY.
RESEND_API_KEY=

# ─── Stripe (registration payments) ─────────────────────────────────────────
# https://dashboard.stripe.com — start in test mode.
# After creating a webhook endpoint pointing at /api/register/stripe/webhook,
# Stripe will give you a signing secret to put in STRIPE_WEBHOOK_SECRET.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Public site URL ────────────────────────────────────────────────────────
# Used by Stripe redirect URLs. On Vercel you can omit and rely on VERCEL_URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
